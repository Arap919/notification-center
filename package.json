{
  "name": "notification-center",
  "version": "0.0.0",
  "scripts": {
    "ng": "node_modules/.bin/ng",
    "build": "ng build",
    "lint": "ng lint",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "teamcity-test": "ng test notification-center --watch=false --browsers=ChromeHeadless",
    "teamcity-build": "npm run lint && npm run teamcity-test && npm run build",
    "lint-fix": "ng lint --fix",
    "prettier-format": "npx prettier . --write",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.16",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.16",
    "@angular/compiler": "20.3.16",
    "@angular/core": "20.3.16",
    "@angular/forms": "20.3.16",
    "@angular/platform-browser": "20.3.16",
    "@angular/platform-browser-dynamic": "20.3.16",
    "@angular/router": "20.3.16",
    "rxjs": "7.8.0",
    "tslib": "2.3.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/build": "20.3.15",
    "@angular/cli": "20.3.15",
    "@angular/compiler-cli": "20.3.16",
    "eslint-plugin-change-detection-strategy": "0.1.4",
    "@tinkoff/eslint-config-angular": "5.1.0",
    "@tinkoff/typescript-config": "5.0.0",
    "@types/jasmine": "5.1.4",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "eslint": "8.57.1",
    "husky": "9.0.10",
    "lint-staged": "13.1.4",
    "jasmine-core": "5.2.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "ng-packagr": "20.3.2",
    "prettier": "3.8.1",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "projects/**/*.{js,ts}": [
      "eslint"
    ],
    "projects/**/*.scss": [
      "stylelint"
    ]
  }
}
